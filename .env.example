# Copy this file to .env and fill in real values.
# Never commit the real .env file.

# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME

GENERIC_TIMEZONE=Africa/Casablanca

# These two are only consumed by tests/test-webhook.sh for manual testing.
# The actual Wazuh Integrator gets its webhook URL from ossec.conf and reads
# the token from /var/ossec/etc/n8n_token, NOT from this file or environment --
# keep the two values below in sync with those if you change one.
WAZUH_N8N_WEBHOOK_URL=http://127.0.0.1:5678/webhook/wazuh-alert
WAZUH_N8N_TOKEN=CHANGE_ME
